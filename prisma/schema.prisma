// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GOOGLE
}

enum TripStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ENDED_EARLY
  ARCHIVED
  CANCELLED
}

enum TripMemberRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
  CANCELLED
}

model User {
  id              String       @id @default(cuid())
  supabaseAuthId  String       @unique
  provider        AuthProvider @default(GOOGLE)
  providerSubject String?      @unique
  email           String       @unique
  fullName        String
  avatarUrl       String?
  username        String?      @unique
  bio             String?
  country         String?

  ownedTrips      Trip[]           @relation("TripOwner")
  tripMembers     TripMember[]
  invitationsSent TripInvitation[] @relation("InvitationInviter")
  invitationsRecv TripInvitation[] @relation("InvitationInvitee")
  ratings         Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id                 String     @id @default(cuid())
  ownerId            String
  title              String
  description        String?
  destination        String
  destinationCountry String?
  destinationCity    String?
  budgetTotal        Decimal?   @db.Decimal(12, 2)
  travelerCount      Int
  startDate          DateTime
  endDate            DateTime
  timezone           String     @default("Asia/Bangkok")
  coverImageUrl      String?
  status             TripStatus @default(DRAFT)
  endedAt            DateTime?
  endedByUserId      String?

  // simple template fields
  isTemplatePublished Boolean   @default(false)
  templatePublishedAt DateTime?
  templateUseCount    Int       @default(0)

  owner       User             @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TripMember[]
  days        TripDay[]
  invitations TripInvitation[]
  ratings     Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([isTemplatePublished])
  @@index([startDate, endDate])
}

model TripMember {
  id            String         @id @default(cuid())
  tripId        String
  userId        String
  role          TripMemberRole @default(MEMBER)
  joinedAt      DateTime       @default(now())
  addedByUserId String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@index([tripId, role])
}

model TripDay {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime
  title     String?
  note      String?

  trip  Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items ItineraryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, dayNumber])
  @@index([tripId, date])
}

model ItineraryItem {
  id              String    @id @default(cuid())
  tripDayId       String
  title           String
  description     String?
  placeName       String?
  placeAddress    String?
  country         String?
  city            String?
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  startTime       DateTime?
  endTime         DateTime?
  estimatedCost   Decimal?  @db.Decimal(12, 2)
  currency        String?   @default("THB")
  note            String?
  sortOrder       Int       @default(0)
  createdByUserId String?
  isCompleted     Boolean   @default(false)

  tripDay TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripDayId, sortOrder])
  @@index([startTime])
}

model TripInvitation {
  id            String           @id @default(cuid())
  tripId        String
  inviterId     String
  inviteeUserId String?
  inviteeEmail  String?
  message       String?
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime?
  respondedAt   DateTime?

  trip    Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  inviter User  @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User? @relation("InvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([inviteeUserId])
  @@index([inviteeEmail])
  @@index([status])
}

model Rating {
  id      String  @id @default(cuid())
  userId  String
  tripId  String
  score   Int
  comment String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tripId])
  @@index([tripId])
}
