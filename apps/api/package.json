{
  "name": "api",
  "module": "./src/index.ts",
  "main": "./dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bunx --bun prisma generate --schema=../../prisma/schema.prisma && bun build --target bun --minify src/index.ts --outdir dist",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.100.1",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "prisma": "^7.6.0"
  }
}
